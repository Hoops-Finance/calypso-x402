# ============================================================================
# Calypso Swarm environment
# ============================================================================

# --- Stellar network ---
SOROBAN_NETWORK=testnet
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org

# --- x402 revenue wallet (populated by `pnpm bootstrap-pay-to`) ---
# Receives all API revenue. Keep the secret safe — never commit.
PAY_TO=
PAY_TO_SECRET=
# Persisted across restarts by the platform wallet boot sequence.
# Reuses an existing smart account instead of deploying a new one on
# every reload. Leave blank on first boot.
PLATFORM_SMART_ACCOUNT_ID=

# Secret key of the admin of the Hoops testnet USDC token contract
# (the same deployer that ran hoops_contracts/deploy-testnet-suite.sh).
# When set, Calypso can mint fresh USDC directly to orchestrator and
# bot smart accounts, bypassing the broken-pool XLM->USDC swap path.
# Never set this in a deployment that handles real funds.
USDC_ADMIN_SECRET=

# --- x402 facilitator ---
X402_FACILITATOR_URL=https://www.x402.org/facilitator
X402_NETWORK=stellar:testnet
# Set to true ONLY for local UI demos. Bypasses payment verification.
X402_DEMO_MODE=false

# --- AI (Gemini 2.5 Flash via Gemini API) ---
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_INTERVAL_MS=300000    # 5 min; override to 60000 for demo mode

# --- Server ---
API_PORT=9990
WEB_PORT=3000
API_BASE_URL=http://localhost:9990
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# --- Hoops data-api (optional, for /analyze enrichment) ---
HOOPS_DATA_API_URL=http://localhost:9991
